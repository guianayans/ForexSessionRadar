{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "sh -c 'if [ -f package.json ]; then npm run dev:web; else cd .. && npm run dev:web; fi'",
    "beforeBuildCommand": "sh -c 'if [ -f package.json ]; then npm run build:stack; else cd .. && npm run build:stack; fi'",
    "devPath": "http://localhost:5173",
    "distDir": "../frontend/dist"
  },
  "package": {
    "productName": "Forex Session Radar",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "notification": {
        "all": true
      },
      "path": {
        "all": false
      },
      "fs": {
        "all": false
      },
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.forexsessionradar.app",
      "resources": ["../frontend/dist"],
      "externalBin": ["binaries/forex-backend"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns"
      ]
    },
    "windows": [
      {
        "title": "Forex Session Radar",
        "width": 1600,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
